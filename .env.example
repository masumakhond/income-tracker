NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Legacy name also supported by the app:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_jwt_key_here

# Auth (required for login)
JWT_SECRET=change-this-to-a-long-random-secret

# Optional: override default admin passwords
# ADMIN_PASSWORD_MASUM=Ma$um@1995
# ADMIN_PASSWORD_TOYEEBA=toyeeb@99
